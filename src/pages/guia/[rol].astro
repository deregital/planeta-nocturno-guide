---
import GuideTopbar from "../../components/GuideTopbar.astro";
import GuideVideoCard from "../../components/GuideVideoCard.astro";
import { getAllSlugs, getRoleBySlug } from "../../data/guide";
import Layout from "../../layouts/Layout.astro";

export function getStaticPaths() {
  return getAllSlugs().map((slug) => ({ params: { rol: slug } }));
}

const { rol } = Astro.params;
const role = getRoleBySlug(rol!);

if (!role) {
  return Astro.redirect("/guia/administrador");
}
---

<Layout title={`${role.label} - Guía Planeta Nocturno`}>
  <GuideTopbar activeSlug={role.slug} />

  <main class="guide-main">
    <h1 class="page-title">{role.label}</h1>

    <div class="video-list">
      {
        role.items.map((item) => (
          <GuideVideoCard title={item.title} video={item.video} />
        ))
      }
    </div>
  </main>
</Layout>

<style>
  .page-title {
    font-size: 1.35rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
  }

  .video-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
</style>
