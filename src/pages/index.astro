---
import Layout from "../layouts/Layout.astro";
import { roles } from "../data/guide";
---

<Layout title="Guía - Planeta Nocturno">
  <main class="home">
    <div class="home-inner">
      <h1 class="hero-title">
        <span class="t-white">Planeta</span><span class="t-primary">Nocturno</span>
      </h1>
      <p class="hero-tag">Guía del sistema</p>
      <p class="hero-desc">
        Seleccioná tu rol para ver los tutoriales paso a paso.
      </p>

      <nav class="role-list">
        {roles.map((role) => (
          <a href={`/guia/${role.slug}`} class="role-item">
            <div class="role-info">
              <span class="role-name">{role.label}</span>
              <span class="role-count">{role.items.length} {role.items.length === 1 ? "tutorial" : "tutoriales"}</span>
            </div>
            <svg class="role-arrow" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="8 5 13 10 8 15" />
            </svg>
          </a>
        ))}
      </nav>
    </div>
  </main>
</Layout>

