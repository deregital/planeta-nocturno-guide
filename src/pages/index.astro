---
import Layout from "../layouts/Layout.astro";
import { roles } from "../data/guide";
---

<Layout title="Guía - Planeta Nocturno">
  <main class="home">
    <div class="home-inner">
      <h1 class="hero-title">
        <span class="t-white">Planeta</span><span class="t-primary">Nocturno</span>
      </h1>
      <p class="hero-tag">Guía del sistema</p>
      <p class="hero-desc">
        Seleccioná tu rol para ver los tutoriales paso a paso.
      </p>

      <nav class="role-list">
        {roles.map((role) => (
          <a href={`/guia/${role.slug}`} class="role-item">
            <div class="role-info">
              <span class="role-name">{role.label}</span>
              <span class="role-count">{role.items.length} {role.items.length === 1 ? "tutorial" : "tutoriales"}</span>
            </div>
            <svg class="role-arrow" width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="8 5 13 10 8 15" />
            </svg>
          </a>
        ))}
      </nav>
    </div>
  </main>
</Layout>

<style>
  .home {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1rem;
  }

  .home-inner {
    width: 100%;
    max-width: 360px;
    text-align: center;
  }

  .hero-title {
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    display: flex;
    justify-content: center;
    gap: 0;
  }

  .t-white {
    color: var(--color-text-heading);
  }

  .t-primary {
    color: var(--color-primary);
  }

  .hero-tag {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
    margin-top: 0.2rem;
  }

  .hero-desc {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin: 1rem 0 1.75rem;
    line-height: 1.5;
  }

  .role-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .role-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
    transition: box-shadow 0.15s, border-color 0.15s;
  }

  .role-item:hover {
    border-color: var(--color-primary-muted);
    box-shadow: var(--shadow);
  }

  .role-info {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .role-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text-heading);
  }

  .role-count {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 1px;
  }

  .role-arrow {
    color: var(--color-border);
    transition: color 0.15s, transform 0.15s;
    flex-shrink: 0;
  }

  .role-item:hover .role-arrow {
    color: var(--color-primary);
    transform: translateX(2px);
  }
</style>
